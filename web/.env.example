DATABASE_URL=postgres://user:password@host/dbname?sslmode=require
AI_SERVICE_URL=http://localhost:8000
INTERNAL_SERVICE_SECRET=change-me-to-a-long-random-string
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

# Auth.js v5 (Google OAuth + database sessions)
AUTH_SECRET=change-me-generate-with-npx-auth-secret
AUTH_GOOGLE_ID=your-google-oauth-client-id
AUTH_GOOGLE_SECRET=your-google-oauth-client-secret
AUTH_URL=http://localhost:3000

# BYOK key encryption at rest (AES-256-GCM). Must decode to exactly 32 bytes.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Never commit the real value. Rotating it requires re-encrypting every api_keys row.
ENCRYPTION_KEY=change-me-base64-32-bytes
