DATABASE_URL=postgres://user:password@host/dbname?sslmode=require
AI_SERVICE_URL=http://localhost:8000
INTERNAL_SERVICE_SECRET=change-me-to-a-long-random-string
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

# Auth.js v5 (Google OAuth + database sessions)
AUTH_SECRET=change-me-generate-with-npx-auth-secret
AUTH_GOOGLE_ID=your-google-oauth-client-id
AUTH_GOOGLE_SECRET=your-google-oauth-client-secret
AUTH_URL=http://localhost:3000

# BYOK key encryption at rest (AES-256-GCM). Must decode to exactly 32 bytes.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Never commit the real value. Rotating it requires re-encrypting every api_keys row.
ENCRYPTION_KEY=change-me-base64-32-bytes

# Platform-owned keys backing the two free-tier models (both have real free
# API tiers, unlike Anthropic/OpenAI) — product-paid, not the user's own key.
# See web/src/lib/generation/modelCatalog.ts.
PLATFORM_GROQ_API_KEY=your-groq-api-key
PLATFORM_GEMINI_API_KEY=your-gemini-api-key

# Trigger.dev v4 (Phase 4 orchestration). TRIGGER_PROJECT_REF comes from
# `npx trigger.dev@latest init` against a real Trigger.dev project.
# TRIGGER_SECRET_KEY is the server access token used to trigger runs from
# Next.js API routes (Phase 5) — not needed just to define/dev-run tasks.
TRIGGER_PROJECT_REF=proj_your-project-ref
TRIGGER_SECRET_KEY=tr_dev_your-secret-key
